---
import { defaultLang } from "../i18n/ui";
import {
	getLangFromUrl,
	getLocalizedPath,
	useTranslations,
} from "../i18n/utils";
import ThemeToggle from "./ThemeToggle.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const currentPath = Astro.url.pathname;

const links = [
	{ href: getLocalizedPath("/", lang), label: t("nav.home") },
	{ href: getLocalizedPath("/about", lang), label: t("nav.about") },
	{ href: getLocalizedPath("/contact", lang), label: t("nav.contact") },
];

function isActive(href: string, current: string): boolean {
	const normalizedHref = href.replace(/\/$/, "") || "/";
	const normalizedCurrent = current.replace(/\/$/, "") || "/";
	if (normalizedHref === "/" || normalizedHref === "/es")
		return normalizedCurrent === normalizedHref;
	return normalizedCurrent.startsWith(normalizedHref);
}

// Build the switch-language URL
function getSwitchLangUrl(): string {
	const targetLang = lang === "en" ? "es" : "en";
	let basePath = currentPath;
	if (lang !== defaultLang) {
		basePath = currentPath.replace(`/${lang}`, "") || "/";
	}
	return getLocalizedPath(basePath, targetLang);
}

const switchLangUrl = getSwitchLangUrl();
const switchLangLabel = lang === "en" ? "ES" : "EN";
---

<header class="sticky top-0 z-50 bg-surface dark:bg-surface-dark/80 dark:backdrop-blur-md border-b border-border dark:border-border-dark">
  <nav class="max-w-[1280px] mx-auto px-6 h-[72px] flex items-center justify-between">
    <a href={getLocalizedPath('/', lang)} class="text-sm font-bold tracking-wider uppercase text-on-surface dark:text-on-surface-dark hover:opacity-70 transition-opacity">
      jarrison.dev
    </a>

    <div class="flex items-center gap-4 md:gap-8">
      <ul class="hidden md:flex items-center gap-8">
        {links.map(link => (
          <li>
            <a
              href={link.href}
              class:list={[
                'text-xs font-medium tracking-widest uppercase transition-all',
                isActive(link.href, currentPath)
                  ? 'text-on-surface dark:text-on-surface-dark underline underline-offset-4 decoration-1'
                  : 'text-muted dark:text-muted-dark hover:text-on-surface dark:hover:text-on-surface-dark',
              ]}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>

      <a
        href={switchLangUrl}
        class="text-xs font-semibold tracking-widest text-muted dark:text-muted-dark hover:text-on-surface dark:hover:text-on-surface-dark transition-colors"
        aria-label={`Switch to ${switchLangLabel === 'ES' ? 'Spanish' : 'English'}`}
      >
        {switchLangLabel}
      </a>

      <ThemeToggle />

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 text-on-surface dark:text-on-surface-dark"
        aria-label="Toggle menu"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-border dark:border-border-dark">
    <ul class="flex flex-col px-6 py-4 gap-4">
      {links.map(link => (
        <li>
          <a
            href={link.href}
            class:list={[
              'text-xs font-medium tracking-widest uppercase',
              isActive(link.href, currentPath)
                ? 'text-on-surface dark:text-on-surface-dark underline underline-offset-4 decoration-1'
                : 'text-muted dark:text-muted-dark',
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
