---
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="max-w-[1280px] mx-auto px-6 pt-12 pb-12 md:pt-16 md:pb-20">
  <p class="animate-in text-xs font-medium tracking-[0.2em] uppercase text-muted dark:text-muted-dark mb-8">
    {t('about.hero.label')}
  </p>
  <h1 class="animate-in animate-in-delay-1 text-4xl md:text-5xl lg:text-6xl font-black leading-[1.05] tracking-tight mb-12 max-w-3xl">
    {t('about.hero.title')}
  </h1>
  <div class="max-w-2xl flex flex-col gap-6">
    <p class="animate-in animate-in-delay-2 text-sm text-muted dark:text-muted-dark leading-relaxed">
      {t('about.hero.p1')}
    </p>
    <p class="animate-in animate-in-delay-3 text-sm text-muted dark:text-muted-dark leading-relaxed">
      {t('about.hero.p2')}
    </p>
  </div>
</section>
