---
const entries = [
  {
    degree: 'Ingeniería de Software (B.Eng.)',
    school: 'Tecnológico de Antioquia',
    period: '2023 — 2027 (Expected)',
    details: 'Relevant coursework: Advanced Databases, Physics, Big Data (MongoDB, CRISP-DM), Legal & Ethical Aspects of Software',
  },
  {
    degree: 'Tecnología en Diseño y Desarrollo Web',
    school: 'Tecnológico de Antioquia',
    period: '2020 — 2024',
    details: 'Associate Degree',
  },
];
---

<section class="max-w-[1280px] mx-auto px-6 py-20 border-t border-border dark:border-border-dark">
  <p class="text-xs font-medium tracking-[0.2em] uppercase text-muted dark:text-muted-dark mb-16">
    Academic Foundation
  </p>

  <div class="flex flex-col">
    {entries.map(entry => (
      <div class="grid grid-cols-1 md:grid-cols-[1fr_auto] gap-2 md:gap-16 py-8 border-b border-border dark:border-border-dark">
        <div>
          <h3 class="text-base font-bold mb-1">{entry.degree}</h3>
          <p class="text-sm text-muted dark:text-muted-dark">{entry.school}</p>
          {entry.details && (
            <p class="text-xs text-muted dark:text-muted-dark mt-2">{entry.details}</p>
          )}
        </div>
        <span class="text-xs font-medium tracking-widest text-muted dark:text-muted-dark">
          {entry.period}
        </span>
      </div>
    ))}
  </div>
</section>
