---
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const entries = [
  {
    degree: t('about.education.degree1'),
    school: t('about.education.school1'),
    period: t('about.education.period1'),
    details: t('about.education.details1'),
  },
  {
    degree: t('about.education.degree2'),
    school: t('about.education.school2'),
    period: t('about.education.period2'),
    details: t('about.education.details2'),
  },
];
---

<section class="max-w-[1280px] mx-auto px-6 py-20 border-t border-border dark:border-border-dark">
  <p class="animate-in text-xs font-medium tracking-[0.2em] uppercase text-muted dark:text-muted-dark mb-16">
    {t('about.education.label')}
  </p>

  <div class="flex flex-col">
    {entries.map(entry => (
      <div class="grid grid-cols-1 md:grid-cols-[1fr_auto] gap-2 md:gap-16 py-8 border-b border-border dark:border-border-dark">
        <div>
          <h3 class="text-base font-bold mb-1">{entry.degree}</h3>
          <p class="text-sm text-muted dark:text-muted-dark">{entry.school}</p>
          {entry.details && (
            <p class="text-xs text-muted dark:text-muted-dark mt-2">{entry.details}</p>
          )}
        </div>
        <span class="text-xs font-medium tracking-widest text-muted dark:text-muted-dark">
          {entry.period}
        </span>
      </div>
    ))}
  </div>
</section>
