---
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const items = [
  {
    number: '01',
    title: t('about.philosophy.01.title'),
    description: t('about.philosophy.01.description'),
  },
  {
    number: '02',
    title: t('about.philosophy.02.title'),
    description: t('about.philosophy.02.description'),
  },
  {
    number: '03',
    title: t('about.philosophy.03.title'),
    description: t('about.philosophy.03.description'),
  },
];
---

<section class="max-w-[1280px] mx-auto px-6 py-20">
  <p class="animate-in text-xs font-medium tracking-[0.2em] uppercase text-muted dark:text-muted-dark mb-16">
    {t('about.philosophy.label')}
  </p>

  <div class="flex flex-col gap-0">
    {items.map(item => (
      <article class="animate-in grid grid-cols-1 md:grid-cols-[140px_1fr] gap-4 md:gap-12 py-12 border-t border-border dark:border-border-dark">
        <span class="text-xs font-medium tracking-widest text-muted dark:text-muted-dark uppercase">
          {item.number} — {t('about.philosophy.suffix')}
        </span>
        <div>
          <h3 class="text-lg font-bold mb-4">{item.title}</h3>
          <p class="text-sm text-muted dark:text-muted-dark leading-relaxed max-w-2xl">
            {item.description}
          </p>
        </div>
      </article>
    ))}
  </div>
</section>
