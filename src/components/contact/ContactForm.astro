<form id="contact-form" class="flex flex-col gap-8">
  <div>
    <label for="name" class="block text-xs font-semibold tracking-widest uppercase mb-3">
      Your Name
    </label>
    <input
      type="text"
      id="name"
      name="name"
      placeholder="Type here..."
      required
      class="w-full bg-transparent border-b border-border dark:border-border-dark pb-3 text-sm outline-none focus:border-on-surface dark:focus:border-on-surface-dark transition-colors placeholder:text-muted/50 dark:placeholder:text-muted-dark/50"
    />
  </div>

  <div>
    <label for="email" class="block text-xs font-semibold tracking-widest uppercase mb-3">
      Email Address
    </label>
    <input
      type="email"
      id="email"
      name="email"
      placeholder="name@example.com"
      required
      class="w-full bg-transparent border-b border-border dark:border-border-dark pb-3 text-sm outline-none focus:border-on-surface dark:focus:border-on-surface-dark transition-colors placeholder:text-muted/50 dark:placeholder:text-muted-dark/50"
    />
  </div>

  <div>
    <label for="inquiry" class="block text-xs font-semibold tracking-widest uppercase mb-3">
      Inquiry
    </label>
    <textarea
      id="inquiry"
      name="inquiry"
      rows="4"
      placeholder="Describe the project..."
      required
      class="w-full bg-transparent border-b border-border dark:border-border-dark pb-3 text-sm outline-none focus:border-on-surface dark:focus:border-on-surface-dark transition-colors resize-none placeholder:text-muted/50 dark:placeholder:text-muted-dark/50"
    ></textarea>
  </div>

  <button
    type="submit"
    class="self-start inline-flex items-center gap-3 bg-on-surface dark:bg-on-surface-dark text-surface dark:text-surface-dark px-8 py-4 text-xs font-semibold tracking-widest uppercase hover:opacity-90 transition-opacity"
  >
    Send Inquiry
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" />
    </svg>
  </button>
</form>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const name = (form.querySelector('#name') as HTMLInputElement).value;
    const email = (form.querySelector('#email') as HTMLInputElement).value;
    const inquiry = (form.querySelector('#inquiry') as HTMLTextAreaElement).value;
    const subject = encodeURIComponent(`Portfolio Inquiry from ${name}`);
    const body = encodeURIComponent(`Name: ${name}\nEmail: ${email}\n\n${inquiry}`);
    window.location.href = `mailto:jarrison.cano@hotmail.com?subject=${subject}&body=${body}`;
  });
</script>
