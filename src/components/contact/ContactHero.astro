---
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="max-w-[1280px] mx-auto px-6 pt-12 pb-8 md:pt-16 md:pb-12">
  <p class="animate-in text-xs font-medium tracking-[0.2em] uppercase text-muted dark:text-muted-dark mb-6">
    {t('contact.hero.label')}
  </p>
  <h1 class="animate-in animate-in-delay-1 text-4xl md:text-6xl lg:text-7xl font-black tracking-tight leading-[1.05] mb-6">
    {t('contact.hero.title')}
  </h1>
  <p class="animate-in animate-in-delay-2 max-w-xl text-base text-muted dark:text-muted-dark leading-relaxed">
    {t('contact.hero.description')}
  </p>
</section>
