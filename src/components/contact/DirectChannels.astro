---
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const channels = [
  { label: 'Email', href: 'mailto:jarrison.cano@hotmail.com', display: 'jarrison.cano@hotmail.com' },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/jarrisoncano/', display: 'linkedin.com/in/jarrisoncano' },
  { label: 'GitHub', href: 'https://github.com/jarrisondev', display: 'github.com/jarrisondev' },
];
---

<div class="bg-surface-alt dark:bg-surface-alt-dark rounded-lg p-8 lg:p-10">
  <p class="text-xs font-semibold tracking-widest uppercase text-muted dark:text-muted-dark mb-8">
    {t('contact.channels.label')}
  </p>

  <div class="flex flex-col gap-6">
    {channels.map(ch => (
      <a
        href={ch.href}
        target={ch.href.startsWith('mailto:') ? undefined : '_blank'}
        rel={ch.href.startsWith('mailto:') ? undefined : 'noopener noreferrer'}
        class="text-lg md:text-xl font-bold uppercase tracking-tight hover:opacity-70 transition-opacity"
      >
        {ch.label}
      </a>
    ))}
  </div>

  <div class="mt-10 pt-6 border-t border-border dark:border-border-dark">
    <p class="text-xs text-muted dark:text-muted-dark tracking-wide">
      <span class="font-semibold uppercase">{t('contact.channels.responseLatency')}</span> {t('contact.channels.responseTime')}
    </p>
    <p class="text-xs text-muted dark:text-muted-dark tracking-wide mt-1">
      <span class="font-semibold uppercase">{t('contact.channels.operatingFrom')}</span> {t('contact.channels.location')}
    </p>
  </div>
</div>
