---
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const experiences = [
	{
		company: "Dash Energy",
		role: t("home.experience.dash.role"),
		period: t("home.experience.dash.period"),
		description: t("home.experience.dash.description"),
		prevRole: t("home.experience.dash.prev.role"),
		prevPeriod: t("home.experience.dash.prev.period"),
		prevDescription: t("home.experience.dash.prev.description"),
	},
	{
		company: "Quantil",
		role: t("home.experience.quantil.role"),
		period: t("home.experience.quantil.period"),
		description: t("home.experience.quantil.description"),
	},
	{
		company: "Waco Digital Hub",
		role: t("home.experience.waco.role"),
		period: t("home.experience.waco.period"),
		description: t("home.experience.waco.description"),
	},
	{
		company: "Atalaya S.A.S",
		role: t("home.experience.atalaya.role"),
		period: t("home.experience.atalaya.period"),
		description: t("home.experience.atalaya.description"),
	},
];
---

<section id="experience" class="max-w-[1280px] mx-auto px-6 py-12 md:py-20">
  <p
    class="animate-in text-xs font-medium tracking-[0.2em] uppercase text-muted dark:text-muted-dark mb-10 md:mb-16"
  >
    {t("home.experience.heading")}
  </p>

  <div class="flex flex-col">
    {
      experiences.map((exp) => (
        <article class="animate-in py-12 border-t border-border dark:border-border-dark">
          {exp.prevRole ? (
            <>
              <h3 class="text-xl md:text-2xl font-bold mb-6">{exp.company}</h3>
              <div class="grid grid-cols-1 md:grid-cols-[1fr_2fr] gap-4 md:gap-16">
                <div class="flex gap-3">
                  <div class="flex flex-col items-center pt-[5px]">
                    <span class="size-2 rounded-full bg-emerald-500 shrink-0" />
                    <span class="w-px flex-1 bg-border dark:bg-border-dark" />
                  </div>
                  <div>
                    <p class="text-xs font-medium tracking-widest uppercase">{exp.role}</p>
                    <span class="text-[11px] tracking-widest text-muted dark:text-muted-dark">{exp.period}</span>
                  </div>
                </div>
                <p class="text-sm text-muted dark:text-muted-dark leading-relaxed max-w-2xl">
                  {exp.description}
                </p>
              </div>
              <div class="grid grid-cols-1 md:grid-cols-[1fr_2fr] gap-4 md:gap-16 mt-6">
                <div class="flex gap-3">
                  <span class="size-2 rounded-full border border-muted/40 dark:border-muted-dark/40 shrink-0 mt-[5px]" />
                  <div>
                    <p class="text-xs font-medium tracking-widest uppercase text-muted dark:text-muted-dark">{exp.prevRole}</p>
                    <span class="text-[11px] tracking-widest text-muted/50 dark:text-muted-dark/50">{exp.prevPeriod}</span>
                  </div>
                </div>
                <p class="text-sm text-muted/60 dark:text-muted-dark/60 leading-relaxed max-w-2xl">
                  {exp.prevDescription}
                </p>
              </div>
            </>
          ) : (
            <>
              <h3 class="text-xl md:text-2xl font-bold mb-6">{exp.company}</h3>
              <div class="grid grid-cols-1 md:grid-cols-[1fr_2fr] gap-4 md:gap-16">
                <div>
                  <p class="text-xs font-medium tracking-widest uppercase text-muted dark:text-muted-dark">
                    {exp.role}
                  </p>
                  <span class="text-[11px] tracking-widest text-muted/50 dark:text-muted-dark/50">
                    {exp.period}
                  </span>
                </div>
                <p class="text-sm text-muted dark:text-muted-dark leading-relaxed max-w-2xl">
                  {exp.description}
                </p>
              </div>
            </>
          )}
        </article>
      ))
    }
  </div>
</section>
