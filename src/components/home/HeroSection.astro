---
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="max-w-[1280px] mx-auto px-6 pt-16 pb-24">
  <p class="text-xs font-medium tracking-[0.2em] uppercase text-muted dark:text-muted-dark mb-6">
    {t('home.hero.subtitle')}
  </p>
  <h1 class="text-6xl md:text-8xl lg:text-9xl font-black uppercase tracking-tighter leading-[0.85] mb-10">
    Jarrison<br />Cano
  </h1>
  <p class="max-w-lg text-base text-muted dark:text-muted-dark leading-relaxed">
    {t('home.hero.description')}
  </p>
</section>
