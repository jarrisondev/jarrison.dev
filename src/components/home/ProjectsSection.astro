---
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const rundevTags = [
	"REACT 19",
	"TYPESCRIPT",
	"CLAUDE AI",
	"SUPABASE",
	"STRAVA",
	"GARMIN",
	"PWA",
];

const ossProjects = [
	{
		name: "La Velada Web",
		description:
			lang === "es"
				? "Sitio oficial del evento de boxeo de Ibai Llanos — millones de visitas en cada edición. Construido con Astro por la comunidad de Midudev."
				: "Official site for Ibai Llanos' boxing event — millions of visits per edition. Built with Astro by Midudev's open source community.",
		href: "https://github.com/midudev/la-velada-web-oficial",
	},
	{
		name: "Aforshow",
		description:
			lang === "es"
				? "Plataforma web del evento anual de la comunidad Afordin. Agenda, speakers, registro y streaming en vivo. Astro + Tailwind."
				: "Web platform for the annual Afordin community event. Schedule, speakers, registration, and live streaming. Astro + Tailwind.",
		href: "https://github.com/afordin/aforshow-2025",
	},
	{
		name: "Hackafor",
		description:
			lang === "es"
				? "Plataforma del hackathon de Afordin — registro de equipos, envío de proyectos y votación. React + UnoCSS, 484+ commits."
				: "Afordin's hackathon platform — team registration, project submissions, and voting. React + UnoCSS, 484+ commits.",
		href: "https://github.com/afordin/hackafor-2",
	},
];
---

<section class="max-w-[1280px] mx-auto px-6 py-12 md:py-20">
  <p class="animate-in text-xs font-medium tracking-[0.2em] uppercase text-muted dark:text-muted-dark mb-10 md:mb-16">
    {t('home.projects.heading')}
  </p>

  <div class="animate-in grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
    <a href="https://rundev.pages.dev" target="_blank" rel="noopener noreferrer" class="group block rounded-lg overflow-hidden bg-surface-alt dark:bg-surface-alt-dark">
      <img
        src="/rundev-preview.png"
        alt="RunDev — AI Running Coach dashboard"
        class="w-full h-auto object-cover group-hover:scale-[1.02] transition-transform duration-300"
        loading="lazy"
      />
    </a>

    <div class="flex flex-col gap-6">
      <div class="flex flex-wrap gap-2">
        {rundevTags.map(tag => (
          <span class="text-[10px] font-semibold tracking-widest uppercase px-3 py-1.5 rounded-full border border-border dark:border-border-dark text-muted dark:text-muted-dark">
            {tag}
          </span>
        ))}
      </div>
      <p class="text-sm text-muted dark:text-muted-dark leading-relaxed max-w-lg">
        {t('home.projects.rundev.description')}
      </p>
      <a
        href="https://rundev.pages.dev"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-xs font-semibold tracking-widest uppercase hover:opacity-70 transition-opacity"
      >
        {t('home.projects.rundev.cta')}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" />
        </svg>
      </a>
    </div>
  </div>

  <!-- Open Source Contributions -->
  <div class="mt-12 pt-12 md:mt-20 md:pt-20 border-t border-border dark:border-border-dark">
    <p class="animate-in text-xs font-medium tracking-[0.2em] uppercase text-muted dark:text-muted-dark mb-12">
      {t('home.projects.oss.heading')}
    </p>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {ossProjects.map((project, i) => (
        <a
          href={project.href}
          target="_blank"
          rel="noopener noreferrer"
          class:list={['animate-in group flex flex-col gap-3 py-6 px-1', i === 1 && 'animate-in-delay-1', i === 2 && 'animate-in-delay-2']}
        >
          <h4 class="text-base font-bold group-hover:opacity-70 transition-opacity">
            {project.name}
          </h4>
          <p class="text-xs text-muted dark:text-muted-dark leading-relaxed">
            {project.description}
          </p>
          <span class="text-[10px] font-semibold tracking-widest uppercase text-muted dark:text-muted-dark group-hover:text-on-surface dark:group-hover:text-on-surface-dark transition-colors mt-auto">
            GitHub →
          </span>
        </a>
      ))}
    </div>
    <div class="animate-in mt-10">
      <a
        href="https://github.com/jarrisondev"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-xs font-semibold tracking-widest uppercase text-muted dark:text-muted-dark hover:text-on-surface dark:hover:text-on-surface-dark transition-colors"
      >
        {lang === 'es' ? 'Ver más en GitHub' : 'See more on GitHub'}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
