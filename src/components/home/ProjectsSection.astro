---
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const tags = ['REACT ROUTER', 'SUPABASE', 'CLAUDE AI'];
---

<section class="max-w-[1280px] mx-auto px-6 py-20">
  <p class="text-xs font-medium tracking-[0.2em] uppercase text-muted dark:text-muted-dark mb-16">
    {t('home.projects.heading')}
  </p>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
    <div class="bg-surface-alt dark:bg-surface-alt-dark rounded-lg p-10 flex items-center justify-center min-h-[280px]">
      <span class="text-4xl md:text-5xl font-black tracking-tight italic">RunDev</span>
    </div>

    <div class="flex flex-col gap-6">
      <div class="flex flex-wrap gap-2">
        {tags.map(tag => (
          <span class="text-[10px] font-semibold tracking-widest uppercase px-3 py-1.5 rounded-full border border-border dark:border-border-dark text-muted dark:text-muted-dark">
            {tag}
          </span>
        ))}
      </div>
      <p class="text-sm text-muted dark:text-muted-dark leading-relaxed max-w-lg">
        {t('home.projects.rundev.description')}
      </p>
      <a
        href="#"
        class="inline-flex items-center gap-2 text-xs font-semibold tracking-widest uppercase hover:opacity-70 transition-opacity"
      >
        {t('home.projects.viewCaseStudy')}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
