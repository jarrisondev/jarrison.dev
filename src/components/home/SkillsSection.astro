---
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const languages = [
	"React / Next.js / React Native",
	"TypeScript / JavaScript",
	"Astro / SvelteKit / Vue",
	"Python / Django",
	"Node.js / NestJS",
	"Java / Spring Boot / Kotlin",
];

const infrastructure = [
	"Azure (Static Web Apps, Functions, RBAC)",
	"AWS / GCP",
	"Docker / CI/CD / GitHub Actions",
	"Supabase / Cloudflare",
	"PostgreSQL / MongoDB / SQL Server",
];
---

<section class="max-w-[1280px] mx-auto px-6 py-12 md:py-20 border-t border-border dark:border-border-dark">
  <p class="animate-in text-xs font-medium tracking-[0.2em] uppercase text-muted dark:text-muted-dark mb-10 md:mb-16">
    {t('home.skills.heading')}
  </p>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-16">
    <div class="animate-in">
      <h3 class="text-sm font-semibold tracking-widest uppercase mb-8">{t('home.skills.languages')}</h3>
      <div class="flex flex-col">
        {languages.map(skill => (
          <div class="py-3 border-b border-border dark:border-border-dark">
            <span class="text-sm">{skill}</span>
          </div>
        ))}
      </div>
    </div>

    <div class="animate-in animate-in-delay-1">
      <h3 class="text-sm font-semibold tracking-widest uppercase mb-8">{t('home.skills.infrastructure')}</h3>
      <div class="flex flex-col">
        {infrastructure.map(skill => (
          <div class="py-3 border-b border-border dark:border-border-dark">
            <span class="text-sm">{skill}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
