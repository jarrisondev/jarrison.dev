---
const coreStack = [
  { name: 'React', level: 'Expert' },
  { name: 'TypeScript', level: 'Expert' },
  { name: 'Python', level: 'Advanced' },
  { name: 'JavaScript', level: 'Expert' },
];

const infrastructure = [
  { name: 'Azure (Static Web Apps, Functions, RBAC)', level: 'Advanced' },
  { name: 'AWS / GCP', level: 'Proficient' },
  { name: 'GitHub Actions', level: 'Advanced' },
  { name: 'Vercel / Supabase', level: 'Advanced' },
];
---

<section class="max-w-[1280px] mx-auto px-6 py-20 border-t border-border dark:border-border-dark">
  <p class="text-xs font-medium tracking-[0.2em] uppercase text-muted dark:text-muted-dark mb-16">
    03 / Technical Stack
  </p>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-16">
    <div>
      <h3 class="text-sm font-semibold tracking-widest uppercase mb-8">Core Stack</h3>
      <div class="flex flex-col">
        {coreStack.map(skill => (
          <div class="flex items-center justify-between py-3 border-b border-border dark:border-border-dark">
            <span class="text-sm">{skill.name}</span>
            <span class="text-xs text-muted dark:text-muted-dark tracking-wider uppercase">{skill.level}</span>
          </div>
        ))}
      </div>
    </div>

    <div>
      <h3 class="text-sm font-semibold tracking-widest uppercase mb-8">Infrastructure</h3>
      <div class="flex flex-col">
        {infrastructure.map(skill => (
          <div class="flex items-center justify-between py-3 border-b border-border dark:border-border-dark">
            <span class="text-sm">{skill.name}</span>
            <span class="text-xs text-muted dark:text-muted-dark tracking-wider uppercase">{skill.level}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
