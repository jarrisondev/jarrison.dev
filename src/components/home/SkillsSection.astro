---
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const coreStack = [
  { name: 'React', level: t('home.skills.expert') },
  { name: 'TypeScript', level: t('home.skills.expert') },
  { name: 'Python', level: t('home.skills.advanced') },
  { name: 'JavaScript', level: t('home.skills.expert') },
];

const infrastructure = [
  { name: 'Azure (Static Web Apps, Functions, RBAC)', level: t('home.skills.advanced') },
  { name: 'AWS / GCP', level: t('home.skills.proficient') },
  { name: 'GitHub Actions', level: t('home.skills.advanced') },
  { name: 'Vercel / Supabase', level: t('home.skills.advanced') },
];
---

<section class="max-w-[1280px] mx-auto px-6 py-20 border-t border-border dark:border-border-dark">
  <p class="text-xs font-medium tracking-[0.2em] uppercase text-muted dark:text-muted-dark mb-16">
    {t('home.skills.heading')}
  </p>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-16">
    <div>
      <h3 class="text-sm font-semibold tracking-widest uppercase mb-8">{t('home.skills.coreStack')}</h3>
      <div class="flex flex-col">
        {coreStack.map(skill => (
          <div class="flex items-center justify-between py-3 border-b border-border dark:border-border-dark">
            <span class="text-sm">{skill.name}</span>
            <span class="text-xs text-muted dark:text-muted-dark tracking-wider uppercase">{skill.level}</span>
          </div>
        ))}
      </div>
    </div>

    <div>
      <h3 class="text-sm font-semibold tracking-widest uppercase mb-8">{t('home.skills.infrastructure')}</h3>
      <div class="flex flex-col">
        {infrastructure.map(skill => (
          <div class="flex items-center justify-between py-3 border-b border-border dark:border-border-dark">
            <span class="text-sm">{skill.name}</span>
            <span class="text-xs text-muted dark:text-muted-dark tracking-wider uppercase">{skill.level}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
