---
import ContactForm from "../../components/contact/ContactForm.astro";
import ContactHero from "../../components/contact/ContactHero.astro";
import DirectChannels from "../../components/contact/DirectChannels.astro";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";
import Layout from "../../layouts/Layout.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title={`${t('nav.contact')} — Jarrison Cano`}>
  <ContactHero />
  <section class="max-w-[1280px] mx-auto px-6 pb-24">
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_380px] gap-12 lg:gap-16">
      <ContactForm />
      <DirectChannels />
    </div>
  </section>
</Layout>
