---
import Layout from '../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title={`${t('work.label')} — Jarrison Cano`}>
  <section class="max-w-[1280px] mx-auto px-6 py-32 flex flex-col items-center justify-center text-center min-h-[60vh]">
    <p class="text-xs font-medium tracking-[0.2em] uppercase text-muted dark:text-muted-dark mb-6">
      {t('work.label')}
    </p>
    <h1 class="text-4xl md:text-5xl font-black tracking-tight mb-4">
      {t('work.title')}
    </h1>
    <p class="text-sm text-muted dark:text-muted-dark max-w-md">
      {t('work.description')}
    </p>
  </section>
</Layout>
